# Copy to .env (gitignored) and fill in to run integration tests against a real
# pwndoc instance. Integration tests are skipped automatically when PWNDOC_URL is unset.
#
# NEVER commit a filled-in copy of this file.

# Base URL of your pwndoc instance, e.g. https://pwndoc.example.com:8443
PWNDOC_URL=

# Credentials for a pwndoc account (admin recommended for full coverage)
PWNDOC_USER=
PWNDOC_PASS=

# Optional TOTP token if the account has 2FA enabled
PWNDOC_TOTP=

# Set to 1 if the instance uses a self-signed TLS certificate
PWNDOC_INSECURE=1
